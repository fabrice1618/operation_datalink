# Modèle de configuration — copier en .env puis renseigner les valeurs.
#   cp .env.example .env
# Le fichier .env réel n'est pas versionné (voir .gitignore).

# Clé de signature des sessions Flask du portail.
# Générer une valeur unique avec :
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Scénario à deux phases. La phase 2 (réquisition P6) nécessite l'infra Docker
# live, inaccessible à certains étudiants.
#   0 = portail en phase 1 uniquement (défaut)
#   1 = active la phase 2 dans le portail
PHASE2_ENABLED=0
